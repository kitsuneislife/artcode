// Exemplo 25 - Loops + Tuplas + Destructuring
// Mostra while/for com tuple literals e pattern binding em let.

let pontos = [
    (1, 2),
    (3, 4),
    (5, 6),
];

let (x0, y0) = (100, 200);
println("tuple inicial:", x0, y0);

for ponto in (pontos) println(ponto);

let sempre_falso = false;
while (sempre_falso) println("nao executa");
